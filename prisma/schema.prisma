generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  schemas  = ["public", "personal_data", "documents"]
}
// ------------------------------------------
// |                 PUBLIC                 |
// ------------------------------------------
model Roles{
  @@schema("public")
  id  Int @id @default(autoincrement())
  role  String  @db.VarChar(15)
  level Int @db.Integer

  people People[]
}
model ContactType {
  @@schema("public")
  id  Int @id @default(autoincrement())
  type String @db.VarChar(15)
  contacts Contact[]
}
model EmployerPost {
  @@schema("public")
  id   Int    @id @default(autoincrement())
  post String @db.VarChar(50)

  employers EmployerListPost[]
}
model VaccinationDetails {
  @@schema("public")
  id              Int       @id @default(autoincrement())

  vaccineId       Int
  visitServiceId  Int       @unique

  batchNumber String @db.VarChar(50)
  expDate         DateTime @db.Date
  nextDueDate     DateTime @db.Date
  AdmSite         String   @db.VarChar(100)
  notes           String?  @db.Text

  visitService    VisitService @relation(fields: [visitServiceId], references: [id])
  vaccine         Vaccine      @relation(fields: [vaccineId], references: [id])
}
model Service {
  @@schema("public")
  id          Int             @id @default(autoincrement())
  name        String          @db.VarChar(100)
  visitServices VisitService[]
}

model Vaccine {
  @@schema("public")
  id          Int       @id @default(autoincrement())
  name        String    @unique @db.VarChar(100)
  vaccinationDetails  VaccinationDetails[]
}
model VisitService {
  @@schema("public")
  id        Int       @id @default(autoincrement())
  notes     String?   @db.Text
  startedAt DateTime  @db.Timestamp(3) @default(now())
  endedAt   DateTime  @db.Timestamp(4) @default(now())

  visitId   Int
  serviceId Int
  doctorId Int
  patientId Int

  visit     Visit     @relation(fields: [visitId], references: [id])
  service   Service   @relation(fields: [serviceId], references: [id])
  doctor    EmployerListPost    @relation(fields: [doctorId], references: [id])
  patient   Patient   @relation(fields: [patientId], references: [id])

  vaccination VaccinationDetails?
}
model Breed {
  @@schema("public")
  id       Int      @id @default(autoincrement())

  name     String   @unique @db.VarChar(100)

  species  String   @default("cat") @db.VarChar(50)

  patients Patient[]
}

model Visit {
  @@schema("public")
  id        Int       @id @default(autoincrement())

  startAt   DateTime  @default(now()) @db.Timestamptz(6)
  endAt     DateTime? @db.Timestamptz(6)

  status    String    @default("open") @db.VarChar(50)

  notes     String?   @db.Text

  patientId Int

  patient   Patient   @relation(fields: [patientId], references: [id])

  services  VisitService[]
}

model OrganizationType{
  @@schema("public")
  id Int @id @default(autoincrement())
  type String @db.VarChar(100)

  organizations contrAgency[]
}

model educationType{
  @@schema("public")
  id Int @id @default(autoincrement())
  type String @db.VarChar(50)

  education educationDocument[]
}
model educationSpecialization{
  @@schema("public")
  id Int @id @default(autoincrement())
  specialization String @db.VarChar(100)
  organizationId Int

  organization contrAgency @relation(fields: [organizationId], references: [id])
  educationDocs educationDocument[]
}

// -----------------------------------------
// |             PERSONAL DATA             |
// -----------------------------------------
model Contact {
  @@schema("personal_data")
  id        Int      @id @default(autoincrement())
  typeId      Int
  value     String   @db.VarChar(50)
  createdAt DateTime @default(now()) @db.Timestamp()

  peopleId    Int?

  type     ContactType       @relation(fields: [typeId], references: [id])
  people    People?    @relation(fields: [peopleId], references: [id])
}
model EmployerListPost {
  @@schema("personal_data")
  id    Int     @id @default(autoincrement())
  employerId Int
  postId     Int

  employer   People     @relation(fields: [employerId], references: [id])
  post       EmployerPost @relation(fields: [postId], references: [id])
  @@unique([employerId, postId])
  doctors VisitService[]
}
model Patient {
  @@schema("personal_data")
  id               Int       @id @default(autoincrement())
  name             String    @db.VarChar(100)
  dateOfBirth      DateTime? @db.Date
  sex              Boolean?  @default(true)
  color            String?   @db.VarChar(50)
  registrationDate DateTime  @default(now()) @db.Timestamptz(6)

  chipNumber       String?   @unique @db.VarChar(50)

  peopleId          Int
  breedId          Int

  owner            People     @relation(fields: [peopleId], references: [id])
  breed            Breed     @relation(fields: [breedId], references: [id])

  visits           Visit[]
  visitServices    VisitService[]
}

model People{
  @@schema("personal_data")
  id  Int @id @default(autoincrement())
  firstName String    @db.VarChar(50)
  lastName  String    @db.VarChar(50)
  birth     DateTime? @db.Date
  address   String?   @db.Text
  createdAt DateTime  @default(now()) @db.Timestamptz(6)
  roleId  Int

  roles  Roles @relation(fields: [roleId], references: [id])

  contacts  Contact[]
  patients  Patient[]
  posts    EmployerListPost[]
  passports Passport[]
}

model contrAgency{
  @@schema("personal_data")
  id Int @id @default(autoincrement())
  name String @db.VarChar(50)
  addres String @db.VarChar(100)
  taxNumber String @db.VarChar(30)
  KPP String? @db.VarChar(30)

  typeOrganizationId Int
  issuePassport Passport[]
  educationDocs educationDocument[]
  educationSpecializations educationSpecialization[]
  type OrganizationType @relation(fields: [typeOrganizationId], references: [id])
}

// -----------------------------------------
// |               DOCUMENTS               |
// -----------------------------------------

model Passport{
  @@schema("documents")
  id Int @id @default(autoincrement())
  serial  String? @db.VarChar(15)
  number  String @db.VarChar(15)
  firstName String @db.VarChar(50)
  lastName String @db.VarChar(50)
  gender  Boolean @db.Boolean()
  birthDay  DateTime @db.Date()
  expiryDate DateTime @db.Date()
  mrzLine1    String  @db.VarChar(50)
  mrzLine2    String  @db.VarChar(50)

  issuedBy Int
  peopleId Int
  people People @relation(fields: [peopleId], references: [id])
  issue  contrAgency @relation(fields: [issuedBy], references: [id])
}

model educationDocument{
  @@schema("documents")
  id Int @id @default(autoincrement())
  typeId Int
  number String @db.VarChar(100)
  dateIssue DateTime @db.Date()
  issueById Int
  withHonors Boolean @db.Boolean()
  specializationId Int

  specialization educationSpecialization @relation(fields: [specializationId], references: [id])
  issueBy contrAgency @relation(fields: [issueById], references: [id])
  type educationType @relation(fields: [typeId], references: [id])
}